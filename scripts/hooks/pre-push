#!/usr/bin/env bash
# Pre-push hook: runs fmt check and clippy before any push.
# Mirrors the CI `just check` step so formatting/lint failures are caught locally.
#
# To skip for a single push: GIT_NO_CHECK=1 git push ...
# To disable permanently: remove .git/hooks/pre-push

set -euo pipefail

if [ "${GIT_NO_CHECK:-0}" = "1" ]; then
    exit 0
fi

if ! command -v cargo &>/dev/null; then
    exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "[check] Running cargo fmt --check..."
if ! cargo fmt --manifest-path "$REPO_ROOT/Cargo.toml" -- --check; then
    echo ""
    echo "[check] Format check failed. Run 'cargo fmt' to fix, then re-push."
    exit 1
fi

echo "[check] Running cargo clippy..."
if ! cargo clippy --manifest-path "$REPO_ROOT/Cargo.toml" -- -D warnings; then
    echo ""
    echo "[check] Clippy failed. Fix the warnings above, then re-push."
    exit 1
fi

echo "[check] All checks passed."
